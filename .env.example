# Sraosha Configuration
# Copy this file to .env and fill in your values
# chmod 600 .env

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (from @userinfobot)
ALLOWED_USER_ID=your_user_id_here

# Full path to Claude CLI (run: which claude)
CLAUDE_PATH=/Users/yourname/.local/bin/claude

# Working directory for Claude tasks
DEFAULT_CWD=/Users/yourname

# Home directory (defaults to $HOME)
# HOME=/Users/yourname

# tmux path (defaults to /opt/homebrew/bin/tmux)
# TMUX_PATH=/opt/homebrew/bin/tmux

# Custom PATH for daemon environment (optional)
# DAEMON_PATH=/Users/yourname/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin
